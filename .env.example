# Copy this file to `.env` and adjust before running `docker compose up -d`.

# Address the service binds/publishes on.
# Set this to your VM's Tailscale IP so the app is ONLY reachable over your
# tailnet (recommended). Find it on the VM with:  tailscale ip -4
# Leave as 0.0.0.0 to listen on all interfaces (less secure).
PUBLISH_ADDR=0.0.0.0
PORT=8000

# Hard storage cap for downloaded videos.
# When exceeded, the OLDEST videos are auto-deleted (FIFO) to make room.
# Accepts suffixes: K, M, G, T  (e.g. 25G).
MAX_BYTES=25G

# Default yt-dlp format. Default = best available video + audio.
YTDLP_FORMAT=bestvideo*+bestaudio/best

# Container for the merged output. mp4 is phone-friendly. Use mkv if you want
# maximum compatibility with exotic 4K codecs (av1/opus) that don't fit in mp4.
MERGE_FORMAT=mp4

# Audio codec for Music/Podcast downloads (these are fetched audio-only).
# mp3 is the most universally compatible; m4a/opus also work.
AUDIO_FORMAT=mp3

# Optional shared secret. Leave EMPTY to rely on Tailscale alone (recommended
# for a private tailnet). If set, the web UI prompts for it once and remembers it.
API_TOKEN=
